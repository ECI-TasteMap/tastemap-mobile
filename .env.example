# TasteMap Mobile — Environment Variables
# Copy this file to .env and fill in the values.

# ── Backend API ─────────────────────────────────────────────────────────────
# Single backend (monolith). Points to the real Render deployment.
# For local development point to your local instance.
EXPO_PUBLIC_API_BASE_URL=https://tastemapbackend.onrender.com

# ── Google Maps (future) ─────────────────────────────────────────────────────
# Required when map/geolocation features are added.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── App environment ──────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development
