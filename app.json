{
  "expo": {
    "name": "tastemap-mobile",
    "slug": "tastemap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-fondo-blanco.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-sin-fondo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-sin-fondo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tastemap.mobile"
    },
    "web": {
      "favicon": "./assets/logo-sin-fondo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c7d643c-733e-43b6-98f4-33f4956a0200"
      }
    },
    "owner": "waldron63s-organization"
  }
}
